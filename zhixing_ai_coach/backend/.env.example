APP_NAME=知行AI教练
APP_VERSION=0.1.0
DEBUG=true

# 用 SQLite 快速起步，生产环境切换为 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./zhixing.db

SECRET_KEY=your-secret-key-change-in-production

# 微信小程序配置
WECHAT_APP_ID=your-app-id              # 小程序 AppID
WECHAT_APP_SECRET=your-app-secret      # 小程序 AppSecret（用于 jscode2session）
WECHAT_MCH_ID=your-merchant-id         # 微信支付商户号
WECHAT_API_KEY=your-api-key            # 微信支付 API Key
WECHAT_NOTIFY_URL=https://your-domain.com/api/payments/notify

# AI API 配置（Claude）
AI_API_KEY=your-anthropic-api-key
AI_API_URL=https://api.anthropic.com/v1/messages
AI_MODEL=claude-sonnet-4-20250514

# 方案定价（单位：分）
PLAN_PRICE=990
